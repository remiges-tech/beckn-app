APP_PORT=8083
APP_ENV=development
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5435
DB_NAME=bap
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# Beckn identity for this BAP.
# BAP_URI goes inside context.bapUri so the adapter/BPP knows where to send callbacks.
BAP_ID=baptest1.remiges.tech
BAP_URI=https://baptest.remiges.tech/bap/receiver
NETWORK_ID=ion.id/ion-winroom-0426

# BPP identity — placed inside context.bppId / context.bppUri.
BPP_ID=bpptest1.remiges.tech
BPP_URI=http://bpptest.remiges.tech/bpp/receiver

# ADAPTER_URL is the ONIX BAP adapter the BAP actually POSTs to.
# Action is appended: <ADAPTER_URL>/select, /init, /confirm …
ADAPTER_URL=https://baptest.remiges.tech/bap/caller

# CDS discover endpoint (Beckn v2 GET /discover)
CDS_DISCOVER_URL=https://34.47.138.217.sslip.io/beckn/discover
