# Copy to .env and fill in your own registered signing keys.
# Values must match the keyManager config in config/local-simple-bap.yaml / local-simple-bpp.yaml
# (copy those from their .example counterparts too).

BAP_PRIVATE_KEY=REPLACE_WITH_YOUR_SIGNING_PRIVATE_KEY
BAP_KEY_ID=REPLACE_WITH_YOUR_SUBSCRIBER_ID|REPLACE_WITH_YOUR_KEY_ID|ed25519

BPP_PRIVATE_KEY=REPLACE_WITH_YOUR_SIGNING_PRIVATE_KEY
BPP_KEY_ID=REPLACE_WITH_YOUR_SUBSCRIBER_ID|REPLACE_WITH_YOUR_KEY_ID|ed25519
